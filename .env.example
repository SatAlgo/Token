# Copy this file to ".env" and fill in values.
# The app runs fine with the defaults below (DEMO payment mode, no real money).

# --- Security ---
# Used to sign JWT tokens AND admin/waiter session cookies. Change in production!
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Owner/admin password — used at /admin/login. Waiter accounts (username +
# password) are created by the admin inside the dashboard, not here.
ADMIN_PASSWORD=tea123

# --- Payments ---
# PAYMENT_MODE = "demo"  -> fake instant payment, no keys needed (great for local dev)
# PAYMENT_MODE = "razorpay" -> real Razorpay test/live checkout
PAYMENT_MODE=demo

# Get these free from https://dashboard.razorpay.com (Test Mode).
# Only needed when PAYMENT_MODE=razorpay.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Shop ---
SHOP_NAME=Vakratunda Misal

# --- Images (Cloudinary, free tier) ---
# Get these free from https://cloudinary.com (Dashboard > Product Environment
# Credentials). If left blank, uploaded item photos are saved locally under
# static/uploads/ instead, so the app still works with no setup.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
